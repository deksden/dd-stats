{
  "name": "dd-stats",
  "description": "Deksden GitHub activity collector, SQLite snapshot exporter, and static dashboard.",
  "private": true,
  "type": "module",
  "scripts": {
    "cdx": "codex resume dd-stats --yolo",
    "collect": "node scripts/fetch-github-activity.mjs",
    "sqlite": "node scripts/export-activity-sqlite.mjs",
    "dashboard": "node scripts/build-dashboard.mjs",
    "build": "node scripts/fetch-github-activity.mjs --years 2025 2026 && node scripts/build-dashboard.mjs",
    "serve": "node scripts/serve.mjs"
  }
}
